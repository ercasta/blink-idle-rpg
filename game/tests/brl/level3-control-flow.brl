// =============================================================================
// Test Level 3: Conditional Logic and Loops
// =============================================================================
// This file tests control flow constructs:
// - if/else statements
// - for loops
// - while loops (if supported)
// - Nested conditionals
// - let statements with expressions
// =============================================================================

// Components for testing control flow
component Health {
    current: integer
    max: integer
}

component Counter {
    value: integer
}

component GameState {
    phase: string
    score: integer
    wave: integer
}

component Enemy {
    tier: integer
    name: string
}

// Simple if statement
rule check_health on HealthCheck(evt: id) {
    if entity.Health.current < 50 {
        entity.Health.current += 10
    }
}

// If-else statement
rule classify_health on HealthClassify(evt: id) {
    if entity.Health.current > 75 {
        let _s: id = schedule HealthStatus { status: "healthy" }
    } else {
        let _s: id = schedule HealthStatus { status: "injured" }
    }
}

// If-else-if chain
rule classify_health_detailed on DetailedHealthCheck(evt: id) {
    if entity.Health.current > 80 {
        let _s: id = schedule HealthStatus { status: "excellent" }
    } else if entity.Health.current > 50 {
        let _s: id = schedule HealthStatus { status: "good" }
    } else if entity.Health.current > 25 {
        let _s: id = schedule HealthStatus { status: "injured" }
    } else {
        let _s: id = schedule HealthStatus { status: "critical" }
    }
}

// Nested conditionals
rule complex_check on ComplexCheck(evt: id) {
    if entity.Health.current > 0 {
        if entity.Health.current < entity.Health.max {
            entity.Health.current += 5
        }
        if entity.Health.current > entity.Health.max {
            entity.Health.current = entity.Health.max
        }
    }
}

// For loop with list literal
rule spawn_multiple on SpawnWave(evt: id) {
    let indices = [0, 1, 2, 3, 4]
    for i in indices {
        let _s: id = schedule [delay: 0.1 * i] SpawnEnemy { index: i }
    }
}

// For loop with entities having
rule damage_all_enemies on AreaDamage(evt: id) {
    let enemies = entities having Enemy
    for enemy in enemies {
        enemy.Health.current -= 20
    }
}

// Let statement with expression
rule calculate_damage on CalculateDamage(evt: id) {
    let baseDamage = 10
    let modifier = 1.5
    let totalDamage = baseDamage * modifier
    entity.Health.current -= totalDamage
}

// Conditional with comparison operators
rule wave_progression on WaveComplete(evt: id) {
    if entity has GameState {
        if entity.GameState.wave < 10 {
            entity.GameState.wave += 1
            entity.GameState.score += 100
        } else {
            let _g: id = schedule GameWon { }
        }
    }
}

// Loop with conditional inside
rule process_enemies on ProcessEnemies(evt: id) {
    let enemies = entities having Enemy
    for enemy in enemies {
        if enemy.Enemy.tier > 2 {
            let _b: id = schedule BossAlert { boss: enemy }
        } else {
            let _e: id = schedule EnemySpotted { enemy: enemy }
        }
    }
}

// Test entity
let participant_one: id = new entity {
    Health { current: 100 max: 100 }
    Counter { value: 0 }
}

let game_state_entity: id = new entity {
    GameState { phase: "playing" score: 0 wave: 1 }
}

let goblin_entity: id = new entity {
    Enemy { tier: 1 name: "Goblin" }
    Health { current: 30 max: 30 }
}

let dragon_entity: id = new entity {
    Enemy { tier: 3 name: "Dragon" }
    Health { current: 200 max: 200 }
}
