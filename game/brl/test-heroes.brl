// =============================================================================
// BLINK IDLE RPG - Test Hero Entities
// =============================================================================
// This file defines four hero entities used by the test harness.
// It is NOT used in production — the React app creates heroes at runtime from
// player selections.  This file exists so `npm run test:harness` can compile
// a fully playable game binary without external runtime data injection.
//
// Hero data mirrors game/app/src/data/heroes.ts and
// packages/blink-engine-wasm-js/build.js (CLASS_BASE_* constants).
// =============================================================================

// Warrior hero — "Aldric"
// Class base stats: HP 250, DMG 28, DEF 12, SPEED 1.0
aldric = new entity {
    Character {
        name: "Aldric"
        class: "Warrior"
        level: 1
        experience: 0
        experienceToLevel: 100
    }
    Health {
        current: 250
        max: 250
    }
    Mana {
        current: 50
        max: 50
    }
    Stats {
        strength: 14
        dexterity: 8
        intelligence: 4
        constitution: 16
        wisdom: 4
    }
    Combat {
        damage: 28
        defense: 12
        attackSpeed: 1.0d
        critChance: 0.08d
        critMultiplier: 1.8d
    }
    Target {
        entity: null
    }
    Team {
        id: "player"
        isPlayer: true
    }
    Skills {
        skill1: "power_strike"
        skill2: "shield_bash"
        skill3: "defensive_stance"
        skill4: "execute"
        skillPoints: 0
    }
    Buffs {
        damageBonus: 0
        defenseBonus: 0
        hasteBonus: 0.0d
        shieldAmount: 0
        regenAmount: 0
    }
    SkillCooldown {
        skill1Cooldown: 0.0d
        skill2Cooldown: 0.0d
        skill3Cooldown: 0.0d
        skill4Cooldown: 0.0d
    }
}

