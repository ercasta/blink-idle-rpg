// ── CLERIC SKILLS ───────────────────────────────────────────────────────────

// Heal (Cleric skill1): heal the most injured ally, costs 15 mana, 4s cooldown
rule use_skill_heal on UseSkill(us: id) {
    if entity has GameState {
let character: id = us.source
        if character.Skills.skill1 == "heal" && us.skillSlot == 1 {
            if character.Mana.current >= 15 {
                character.Mana.current -= 15
                // Find most injured ally
let players: list = entities having Team
let lowestRatio: decimal = 1.0d
let healTarget: id = character
                for player in players {
                    if player.Team.isPlayer && player.Health.current > 0 {
let ratio: decimal = player.Health.current / player.Health.max
                        if ratio < lowestRatio {
                            lowestRatio = ratio
                            healTarget = player
                        }
                    }
                }
let healAmount: integer = 20 + character.Stats.wisdom * 3
                healTarget.Health.current += healAmount
                if healTarget.Health.current > healTarget.Health.max {
                    healTarget.Health.current = healTarget.Health.max
                }
                character.SkillCooldown.skill1Cooldown = 4.0d
            }
        }
    }
}

