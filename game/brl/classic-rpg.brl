// ── BUFF REMOVAL ────────────────────────────────────────────────────────────

// Generic buff removal handler (removes temporary buffs after duration expires)
rule remove_buff_handler on RemoveBuff(rb: id) {
    if entity has GameState {
let target: id = rb.source
        if target.Health.current > 0 {
            if rb.buffType == "damageBonus" {
                target.Buffs.damageBonus -= rb.amount
                if target.Buffs.damageBonus < 0 {
                    target.Buffs.damageBonus = 0
                }
            }
            if rb.buffType == "defenseBonus" {
                target.Buffs.defenseBonus -= rb.amount
                if target.Buffs.defenseBonus < 0 {
                    target.Buffs.defenseBonus = 0
                }
            }
            if rb.buffType == "defenseRestore" {
                target.Buffs.defenseBonus += rb.amount
            }
            if rb.buffType == "hasteRestore" {
                target.Buffs.hasteBonus += 0.3d
            }
            if rb.buffType == "evadeEnd" {
                target.Buffs.defenseBonus -= 4
                target.Buffs.hasteBonus -= 0.3d
            }
            if rb.buffType == "smokeEnd" {
                target.Buffs.defenseBonus -= 6
                target.Buffs.hasteBonus -= 0.4d
            }
        }
    }
}

// ── HEALTH REGENERATION ─────────────────────────────────────────────────────

// Passive health regen for heroes (moderate and steady)
rule health_regen on HealthRegen(hr: id) {
    if entity has GameState {
let character: id = hr.source
        if character.Health.current > 0 {
let regenAmount: integer = 5 + character.Buffs.regenAmount
            character.Health.current += regenAmount
            if character.Health.current > character.Health.max {
                character.Health.current = character.Health.max
            }
            schedule [delay: 2.0d] HealthRegen {
                source: character
            }
        }
    }
}

// Mana regeneration
rule mana_regen on ManaRegen(mr: id) {
    if entity has GameState {
let character: id = mr.source
        if character.Health.current > 0 {
            character.Mana.current += 5
            schedule [delay: 2] ManaRegen {
                source: character
            }
        }
    }
}

// Spawn next enemy wave - REMOVED
// Wave spawning is now handled by handle_enemy_spawned rule which uses tiered progression

// Count player deaths
rule count_player_death on PlayerDefeated(pd: id) {
    if entity has GameState {
        entity.GameState.playerDeaths += 1
    }
}

// Apply death penalty to run stats
rule apply_death_penalty on PlayerDefeated(pd: id) {
    if entity has RunStats {
let fleeConfigs: list = entities having FleeConfig
        if len(fleeConfigs) > 0 {
let fleeConfig: id = fleeConfigs[0]
            entity.RunStats.deathPenalty += fleeConfig.FleeConfig.retreatTimePenalty * fleeConfig.FleeConfig.deathTimePenaltyMultiplier
            entity.RunStats.totalTime = entity.RunStats.simulationTime + entity.RunStats.retreatPenalty + entity.RunStats.deathPenalty
            schedule UpdateRunStats {
            }
        }
    }
}

// Game over on all players dead
// NOTE: Removed automatic game-over when all players die. The game
// now continues (players will respawn) and only finishes when the
// final boss (Lord Vexar) is defeated.

// Victory check - REMOVED
// Victory is now only achieved by defeating Lord Vexar (handled in boss_defeated_victory rule)
// The game continues even if all heroes die - they respawn after 120 seconds

// Acquire skill
rule acquire_skill on AcquireSkill(as: id) {
    if entity has GameState {
let character: id = as.source
        if character.Skills.skillPoints > 0 {
            character.Skills.skillPoints -= 1
            schedule SkillAcquired {
                character: character
            }
        }
    }
}

// Flee from battle - player initiates retreat
rule flee_battle on FleeFromBattle(fb: id) {
    if entity has RunStats {
let fleeConfigs: list = entities having FleeConfig
        if len(fleeConfigs) > 0 {
let fleeConfig: id = fleeConfigs[0]
let timeSinceFlee: decimal = entity.RunStats.simulationTime - entity.RunStats.lastFleeTime
            if timeSinceFlee >= fleeConfig.FleeConfig.fleeCooldown {
                entity.RunStats.retreatCount += 1
                entity.RunStats.retreatPenalty += fleeConfig.FleeConfig.retreatTimePenalty
                entity.RunStats.lastFleeTime = entity.RunStats.simulationTime
                entity.RunStats.canFlee = false
                entity.RunStats.totalTime = entity.RunStats.simulationTime + entity.RunStats.retreatPenalty + entity.RunStats.deathPenalty
                schedule DespawnAllEnemies {
                }
let gameStateEntities: list = entities having GameState
                if len(gameStateEntities) > 0 {
                    schedule [delay: 0.5d] SpawnEnemyWave {
                        target: gameStateEntities[0]
                    }
                }
                schedule UpdateRunStats {
                }
            }
        }
    }
}

// Despawn all enemies on flee
rule despawn_enemies on DespawnAllEnemies(dae: id) {
    if entity has GameState {
let enemies: list = entities having Enemy
        for enemy in enemies {
            if enemy.Enemy.tier > 0 {
                enemy.Health.current = 0
                schedule RemoveEntity {
                    target: enemy
                }
            }
        }
    }
}

// Spawn a new wave after fleeing
rule spawn_wave_after_flee on SpawnEnemyWave(sew: id) {
    if entity has GameState {
let spawner: id = sew.target
        schedule [delay: 0.1d] EnemySpawned {
            wave: spawner.GameState.currentWave
        }
    }
}

// Update flee cooldown timer
rule update_flee_cooldown on UpdateRunStats(urs: id) {
    if entity has RunStats {
let fleeConfigs: list = entities having FleeConfig
        if len(fleeConfigs) > 0 {
let fleeConfig: id = fleeConfigs[0]
let timeSinceFlee: decimal = entity.RunStats.simulationTime - entity.RunStats.lastFleeTime
            if timeSinceFlee >= fleeConfig.FleeConfig.fleeCooldown {
                entity.RunStats.canFlee = true
            }
        }
    }
}

// Complete run and save to leaderboard
rule complete_run on GameOver(go: id) {
    if entity has RunStats {
let gameStates: list = entities having GameState
        if len(gameStates) > 0 {
let gameState: id = gameStates[0]
            schedule SaveRunToLeaderboard {
                completionTime: entity.RunStats.totalTime
                enemiesDefeated: gameState.GameState.enemiesDefeated
                playerDeaths: gameState.GameState.playerDeaths
                retreats: entity.RunStats.retreatCount
                retreatPenalty: entity.RunStats.retreatPenalty
                deathPenalty: entity.RunStats.deathPenalty
                victory: gameState.GameState.victory
            }
        }
    }
}

// Start global recurring retargeting when game begins
rule start_global_retargeting on EnemySpawned(es: id) {
    if entity has GameState {
        if entity.GameState.currentWave == 1 {
            if entity.GameState.retargetingActive == false {
                entity.GameState.retargetingActive = true
                schedule [delay: 2.0d] CheckAllTargets {
                }
            }
        }
    }
}

// Check if entity needs retargeting
rule check_entity_target on CheckAllTargets(cat: id) {
    if entity has Target {
        if entity.Health.current > 0 {
            // Skip enemy templates using direct component access (O(1) vs O(N))
            if entity has EnemyTemplate {
                if entity.EnemyTemplate.isTemplate == false {
let target: id = entity.Target.entity
                    if target == null || target.Health.current <= 0 {
                        schedule FindNewTarget {
                            seeker: entity
                        }
                    }
                }
            } else {
                // Non-enemy entity (hero, etc.)
let target: id = entity.Target.entity
                if target == null || target.Health.current <= 0 {
                    schedule FindNewTarget {
                        seeker: entity
                    }
                }
            }
        }
    }
}

// Reschedule the next retargeting check (makes it recurring)
rule reschedule_retargeting on CheckAllTargets(cat: id) {
    if entity has GameState {
        if entity.GameState.retargetingActive {
            if entity.GameState.gameOver == false {
                schedule [delay: 2.0d] CheckAllTargets {
                }
            }
        }
    }
}

// ============================================================================
// TARGET ASSIGNMENT RULES
// ============================================================================

// Find and assign a new target for an entity
rule find_new_target on FindNewTarget(fnt: id) {
let seeker: id = fnt.seeker
    
    // Determine if seeker is a player or enemy
    if seeker.Team.isPlayer {
        // Player characters target enemies:
        // look for non-template Enemy entities that are alive
let enemies: list = entities having Enemy
let foundTarget: boolean = false
        for enemy in enemies {
            if foundTarget == false {
                if enemy.EnemyTemplate.isTemplate == false {
                    if enemy.Health.current > 0 {
                        // Found a valid target — just update; the existing
                        // attack loop will pick it up on the next tick
                        seeker.Target.entity = enemy
                        foundTarget = true
                    }
                }
            }
        }
        // No valid enemy target found - clear target
        if foundTarget == false {
            seeker.Target.entity = null
        }
    } else {
        // Enemy characters target players
let players: list = entities having Team
let foundTarget: boolean = false
        for player in players {
            // Only process if we haven't found a target yet
            if foundTarget == false {
                if player.Team.isPlayer {
                    if player.Health.current > 0 {
                        // Found a valid target — just update; the existing
                        // attack loop will pick it up on the next tick
                        seeker.Target.entity = player
                        foundTarget = true
                    }
                }
            }
        }
        // No valid player target found - clear target
        if foundTarget == false {
            seeker.Target.entity = null
        }
    }
}

// ============================================================================
// SCORING RULES
// ============================================================================

// Award kill points when a non-boss enemy is defeated
rule update_kill_score on EnemyDefeated(ed: id) {
    if entity has Score {
        if entity has ScoringRules {
            if ed.isBoss == false {
let pts: integer = entity.ScoringRules.pointsPerKill
                entity.Score.killScore += pts
                entity.Score.total += pts
            }
        }
    }
}

// Award boss points when a boss is defeated
rule update_boss_score on EnemyDefeated(ed: id) {
    if entity has Score {
        if entity has ScoringRules {
            if ed.isBoss {
let pts: integer = entity.ScoringRules.pointsPerBoss
                entity.Score.bossScore += pts
                entity.Score.bossesDefeated += 1
                entity.Score.total += pts
            }
        }
    }
}

// Deduct score when a player hero dies
rule update_death_score on PlayerDefeated(pd: id) {
    if entity has Score {
        if entity has ScoringRules {
let penalty: integer = entity.ScoringRules.pointsLostPerDeath
            entity.Score.deathPenaltyTotal += penalty
            entity.Score.total -= penalty
        }
    }
}

// Compute final score on game over (speed bonus + time penalty)
rule compute_final_score on GameOver(go: id) {
    if entity has Score {
        if entity has ScoringRules {
let runStatsEntities: list = entities having RunStats
            if len(runStatsEntities) > 0 {
let runStats: id = runStatsEntities[0]

                // Speed bonus: decays with total time; floor-divide by interval to get whole steps
let timeBonusPts: integer = entity.ScoringRules.timeBonusPoints
let interval: decimal = entity.ScoringRules.timeBonusInterval
let totalTime: decimal = runStats.RunStats.totalTime
let decayed: integer = floor(totalTime / interval)
let speedBonus: integer = max(0, timeBonusPts - decayed)
                entity.Score.speedBonus = speedBonus
                entity.Score.total += speedBonus

                // Time-based penalty from death/retreat seconds
let penaltySeconds: decimal = runStats.RunStats.deathPenalty + runStats.RunStats.retreatPenalty
let timePenalty: integer = penaltySeconds * entity.ScoringRules.pointsLostPerPenaltySecond
                entity.Score.timePenaltyTotal = timePenalty
                entity.Score.total -= timePenalty

                // Retreat count penalty
let retreatCount: integer = runStats.RunStats.retreatCount
let retreatPenalty: integer = retreatCount * entity.ScoringRules.pointsLostPerRetreat
                entity.Score.retreatPenaltyTotal = retreatPenalty
                entity.Score.total -= retreatPenalty
            }
        }
    }
}

// ============================================================================
// PROGRESS CHECKPOINT RULES (N-step UI replay system)
// Fires ProgressCheckpoint every checkpointInterval encounters completed.
// Default: N=30 checkpoints, one per 100 encounters (3000 total encounters).
// ============================================================================

// Check and fire a progress checkpoint after each enemy is defeated.
// Since encounter_tracking runs before this rule and has already incremented
// encounterCount when the last enemy of an encounter dies, the updated
// encounterCount is visible here.
rule check_progress_checkpoint on EnemyDefeated(ed: id) {
    if entity has ProgressTracker {
        if entity has GameState {
            // Cap at totalCheckpoints
            if entity.ProgressTracker.checkpointsReached < entity.ProgressTracker.totalCheckpoints {
let nextThreshold: integer = (entity.ProgressTracker.checkpointsReached + 1) * entity.ProgressTracker.checkpointInterval
                if entity.GameState.encounterCount >= nextThreshold {
                    entity.ProgressTracker.checkpointsReached += 1
                    // Look up simulation time from RunStats entity
let runStatsEntities: list = entities having RunStats
let simTime: decimal = 0.0d
                    if len(runStatsEntities) > 0 {
                        simTime = runStatsEntities[0].RunStats.simulationTime
                    }
                    schedule ProgressCheckpoint {
                        step: entity.ProgressTracker.checkpointsReached
                        enemiesDefeated: entity.GameState.enemiesDefeated
                        simulationTime: simTime
                        currentTier: entity.GameState.currentTier
                        currentWave: entity.GameState.currentWave
                    }
                }
            }
        }
    }
}
