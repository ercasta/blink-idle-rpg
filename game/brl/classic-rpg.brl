// Multi Shot (Ranger skill2): hits multiple targets, 10s cooldown
rule use_skill_multi_shot on UseSkill(us: id) {
    if entity has GameState {
let character: id = us.source
        if character.Skills.skill2 == "multi_shot" && us.skillSlot == 2 {
let enemies: list = entities having Enemy
let hitCount: integer = 0
            for enemy in enemies {
                if hitCount < 3 {
                    if enemy.EnemyTemplate.isTemplate == false && enemy.Health.current > 0 {
let multiDmg: integer = character.Combat.damage / 2 + character.Stats.dexterity
                        if character has DamageType {
                            if enemy has Resistance {
let mscr: integer = 0
                                if character.DamageType.category == "physical" { mscr = enemy.Resistance.physical }
                                if character.DamageType.category == "magical" { mscr = enemy.Resistance.magical }
                                multiDmg = reduce_by_resist(multiDmg, mscr)
                            }
                        }
                        enemy.Health.current -= multiDmg
                        hitCount += 1
                        schedule AfterAttack {
                            attacker: character
                            target: enemy
                        }
                    }
                }
            }
            character.SkillCooldown.skill2Cooldown = 10.0d
        }
    }
}

