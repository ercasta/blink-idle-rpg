        if character.Skills.skill3 == "consecrate" && us.skillSlot == 3 {
let enemies: list = entities having Enemy
let hitCount: integer = 0
            for enemy in enemies {
                if hitCount < 4 {
                    if enemy.EnemyTemplate.isTemplate == false && enemy.Health.current > 0 {
let consecDmg: integer = character.Stats.wisdom * 2
                        if character has DamageType {
                            if enemy has Resistance {
let cscr: integer = 0
                                if character.DamageType.category == "physical" { cscr = enemy.Resistance.physical }
                                if character.DamageType.category == "magical" { cscr = enemy.Resistance.magical }
                                consecDmg = reduce_by_resist(consecDmg, cscr)
                            }
                        }
                        enemy.Health.current -= consecDmg
                        hitCount += 1
                        schedule AfterAttack {
                            attacker: character
                            target: enemy
                        }
                    }
                }
            }
            character.SkillCooldown.skill3Cooldown = 10.0d
        }
    }
}

// Lay on Hands (Paladin skill4): massive heal on self or ally, 20s cooldown
rule use_skill_lay_on_hands on UseSkill(us: id) {
    if entity has GameState {
let character: id = us.source
        if character.Skills.skill4 == "lay_on_hands" && us.skillSlot == 4 {
            // Heal the most injured ally
let players: list = entities having Team
let lowestHp: integer = 9999
let healTarget: id = character
            for player in players {
                if player.Team.isPlayer && player.Health.current > 0 {
                    if player.Health.current < lowestHp {
                        lowestHp = player.Health.current
                        healTarget = player
                    }
                }
            }
let healAmount: integer = 50 + character.Stats.wisdom * 4
            healTarget.Health.current += healAmount
            if healTarget.Health.current > healTarget.Health.max {
                healTarget.Health.current = healTarget.Health.max
            }
            character.SkillCooldown.skill4Cooldown = 20.0d
        }
    }
}

