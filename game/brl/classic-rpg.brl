// Holy Strike (Paladin skill1): damage + small self-heal, 6s cooldown
rule use_skill_holy_strike on UseSkill(us: id) {
    if entity has GameState {
let character: id = us.source
        if character.Skills.skill1 == "holy_strike" && us.skillSlot == 1 {
            if character.Target.entity != null {
let target: id = character.Target.entity
                if target.Health.current > 0 {
let holyDmg: integer = character.Combat.damage + character.Stats.wisdom
                    if character has DamageType {
                        if target has Resistance {
let hscr: integer = 0
                            if character.DamageType.category == "physical" { hscr = target.Resistance.physical }
                            if character.DamageType.category == "magical" { hscr = target.Resistance.magical }
                            holyDmg = reduce_by_resist(holyDmg, hscr)
                        }
                    }
                    target.Health.current -= holyDmg
                    // Self-heal from holy power
let selfHeal: integer = 5 + character.Stats.wisdom
                    character.Health.current += selfHeal
                    if character.Health.current > character.Health.max {
                        character.Health.current = character.Health.max
                    }
                    character.SkillCooldown.skill1Cooldown = 6.0d
                    schedule AfterAttack {
                        attacker: character
                        target: target
                    }
                }
            }
        }
    }
}

